{
  "version": 2,
  "installCommand": "pip install -r requirements.txt",
  "buildCommand": "bash build.sh",
  "builds": [
    {
      "src": "portfolio/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "portfolio/wsgi.py"
    }
  ]
}